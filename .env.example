# HOSE — HOPR Session Explorer
# Copy to .env and adjust as needed.

# gRPC OTLP receiver address (traces, metrics, logs)
HOSE_GRPC_LISTEN=0.0.0.0:4317

# HTTP web UI and API address
HOSE_HTTP_LISTEN=0.0.0.0:8080

# SQLite database file path
HOSE_DATABASE_PATH=hose.db

# Completed debug session data retention (hours)
HOSE_RETENTION_HOURS=24

# Write buffer: max records before flush
HOSE_WRITE_BUFFER_SIZE=1000

# Write buffer: max seconds between flushes
HOSE_WRITE_BUFFER_FLUSH_SECS=5

# Blokli GraphQL indexer endpoint (optional, for channel topology)
# HOSE_INDEXER_ENDPOINT=http://localhost:8000/graphql

# Rust log level filter
RUST_LOG=info
